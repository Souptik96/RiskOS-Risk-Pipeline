# Risk Pipeline Environment Configuration
# Copy this file to .env and update with your values

# =============================================================================
# Application Settings
# =============================================================================

# Application name (used for logging and metrics)
APP_NAME=risk-pipeline

# Application version
APP_VERSION=1.0.0

# Debug mode (true/false)
DEBUG=false

# Host and port for the application
HOST=0.0.0.0
PORT=7861

# =============================================================================
# Model Configuration
# =============================================================================

# Path to the LightGBM model file
MODEL_PATH=model_artifacts/risk_lgbm.txt

# Path to model metadata
METADATA_PATH=model_artifacts/metadata.json

# =============================================================================
# Processing Configuration
# =============================================================================

# Maximum number of transactions per batch
MAX_BATCH_SIZE=1000

# Processing timeout in milliseconds
PROCESSING_TIMEOUT_MS=30000

# Enable batch processing optimization
ENABLE_BATCH_OPTIMIZATION=true

# =============================================================================
# API Configuration
# =============================================================================

# API prefix for all endpoints
API_PREFIX=/api/v1

# Enable CORS (set to true for development)
ENABLE_CORS=false

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# API rate limiting (requests per minute)
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log format (json, text)
LOG_FORMAT=json

# Log file path (leave empty to log to console)
LOG_FILE_PATH=

# Enable request logging
LOG_REQUESTS=true

# Enable response logging
LOG_RESPONSES=false

# =============================================================================
# Security Configuration
# =============================================================================

# Secret key for JWT tokens (generate a secure random string)
SECRET_KEY=your-secret-key-here

# API key for external service authentication (optional)
API_KEY=

# Enable HTTPS (set to true in production)
ENABLE_HTTPS=false

# SSL certificate path (if HTTPS enabled)
SSL_CERT_PATH=

# SSL private key path (if HTTPS enabled)
SSL_KEY_PATH=

# =============================================================================
# External Service Configuration
# =============================================================================

# LLM API key (for GPT rule refinement - optional)
LLM_API_KEY=your_openai_key_here

# Opik API key (for audit logging - optional)
OPIK_API_KEY=your_opik_key_here

# External fraud intelligence service URL
FRAUD_INTELLIGENCE_URL=

# External identity verification service URL
IDENTITY_VERIFICATION_URL=

# External sanctions screening service URL
SANCTIONS_SCREENING_URL=

# =============================================================================
# Monitoring and Metrics
# =============================================================================

# Enable Prometheus metrics
ENABLE_METRICS=true

# Metrics port (if different from main port)
METRICS_PORT=

# Enable health check endpoint
ENABLE_HEALTH_CHECK=true

# Health check interval in seconds
HEALTH_CHECK_INTERVAL=30

# =============================================================================
# Performance Configuration
# =============================================================================

# Number of worker processes (for production deployment)
WORKER_COUNT=4

# Maximum request size in bytes
MAX_REQUEST_SIZE=10485760  # 10MB

# Keep-alive timeout in seconds
KEEP_ALIVE_TIMEOUT=5

# Graceful shutdown timeout in seconds
GRACEFUL_SHUTDOWN_TIMEOUT=30

# =============================================================================
# Feature Flags
# =============================================================================

# Enable ML model scoring
ENABLE_ML_SCORING=true

# Enable rule engine
ENABLE_RULE_ENGINE=true

# Enable decision confidence scoring
ENABLE_CONFIDENCE_SCORING=true

# Enable workload reduction calculation
ENABLE_WORKLOAD_REDUCTION_CALC=true

# Enable rule hit tracking
ENABLE_RULE_HIT_TRACKING=true

# Enable audit logging
ENABLE_AUDIT_LOGGING=true

# =============================================================================
# Development Settings
# =============================================================================

# Enable auto-reload for development (requires uvicorn with reload)
RELOAD=false

# Enable test mode (disables some external dependencies)
TEST_MODE=false

# Mock external services in development
MOCK_EXTERNAL_SERVICES=false

# =============================================================================
# Example Configuration for Development
# =============================================================================
# 
# For local development, you might want to use:
# 
# DEBUG=true
# ENABLE_CORS=true
# CORS_ORIGINS=http://localhost:3000
# LOG_LEVEL=DEBUG
# LOG_FORMAT=text
# RELOAD=true
# MOCK_EXTERNAL_SERVICES=true
# TEST_MODE=true
#
# =============================================================================
#
# Example Configuration for Production:
# 
# DEBUG=false
# ENABLE_CORS=false
# LOG_LEVEL=INFO
# LOG_FORMAT=json
# ENABLE_HTTPS=true
# SSL_CERT_PATH=/etc/ssl/certs/cert.pem
# SSL_KEY_PATH=/etc/ssl/private/key.pem
# WORKER_COUNT=4
# MAX_BATCH_SIZE=1000
# ENABLE_METRICS=true
# ENABLE_AUDIT_LOGGING=true
#
# =============================================================================